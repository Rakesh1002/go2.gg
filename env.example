# =============================================================================
# Go2.gg - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787

# -----------------------------------------------------------------------------
# Site Branding
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=Go2
NEXT_PUBLIC_SITE_TAGLINE=The open-source, edge-native URL shortener
NEXT_PUBLIC_SITE_DESCRIPTION=Go2 is a blazing-fast, open-source URL shortener built for the edge. Create, manage, and track your short links with ease.
NEXT_PUBLIC_CREATOR_NAME=Go2.gg
NEXT_PUBLIC_CONTACT_EMAIL=hello@go2.gg
NEXT_PUBLIC_PRIMARY_COLOR=#6366f1
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/go2dotgg
NEXT_PUBLIC_GITHUB_URL=https://github.com/go2dotgg

# -----------------------------------------------------------------------------
# Default Domain for Short Links
# -----------------------------------------------------------------------------
DEFAULT_DOMAIN=go2.gg

# -----------------------------------------------------------------------------
# Adapter Selection (configures which providers to use)
# -----------------------------------------------------------------------------
AUTH_PROVIDER=supabase
DB_PROVIDER=d1
PAYMENT_PROVIDER=stripe
ANALYTICS_PROVIDER=cloudflare
RATE_LIMIT_PROVIDER=durable-object
STORAGE_PROVIDER=r2

# -----------------------------------------------------------------------------
# Supabase (Auth)
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Cloudflare
# -----------------------------------------------------------------------------
# Get these from your Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# D1 Database (created via: wrangler d1 create go2-db)
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id
CLOUDFLARE_D1_DATABASE_NAME=go2-db

# KV Namespaces (created via: wrangler kv:namespace create <name>)
CLOUDFLARE_KV_CONFIG_ID=your-kv-config-namespace-id
CLOUDFLARE_KV_LINKS_ID=your-kv-links-namespace-id

# R2 Bucket (created via: wrangler r2 bucket create go2-assets)
CLOUDFLARE_R2_BUCKET_NAME=go2-assets

# -----------------------------------------------------------------------------
# Stripe (Payments)
# -----------------------------------------------------------------------------
# Get these from your Stripe dashboard
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Price IDs for Go2 plans (create in Stripe Dashboard)
STRIPE_PRICE_FREE_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_BUSINESS_MONTHLY=price_xxx
STRIPE_PRICE_BUSINESS_ANNUAL=price_xxx

# -----------------------------------------------------------------------------
# PostHog (Analytics & Feature Flags) - Optional
# -----------------------------------------------------------------------------
# Get these from your PostHog project settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Sentry (Error Tracking) - Optional
# -----------------------------------------------------------------------------
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# -----------------------------------------------------------------------------
# Email (Cloudflare Email Sending Service)
# -----------------------------------------------------------------------------
# Outbound email uses the [[send_email]] binding (EMAIL) declared in
# apps/api/wrangler.toml. go2.gg is already verified in the CF dashboard, so
# no API key is required. Only the From-address overrides live here.
EMAIL_FROM_TRANSACTIONAL=Go2 <noreply@go2.gg>
EMAIL_FROM_MARKETING=Rakesh <rakesh@go2.gg>

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a random 32+ character string for CSRF protection
CSRF_SECRET=generate-a-32-character-random-string-here

# Cloudflare Turnstile for bot protection (required for /api/v1/abuse)
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Trust & Safety — destination URL threat checks (recommended in production)
# -----------------------------------------------------------------------------
# Google Safe Browsing v4 Lookup API key — 10k requests/day free tier.
# Create at https://console.cloud.google.com/apis/api/safebrowsing.googleapis.com
# then restrict to safebrowsing.googleapis.com. Without it, link create-time
# checks fail open ("unknown" verdict) and rely entirely on the daily rescan
# + interstitial.
GOOGLE_SAFE_BROWSING_API_KEY=

# Cloudflare URL Scanner v2 second-layer phishing classifier (optional but
# recommended — covers what Safe Browsing hasn't seen yet). Needs an API
# token with `Account → URL Scanner → Read` scope.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_URLSCANNER_TOKEN=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_MAINTENANCE_MODE=false
FEATURE_ENABLE_SIGNUP=true
FEATURE_ENABLE_OAUTH_GOOGLE=true
FEATURE_ENABLE_OAUTH_GITHUB=true
FEATURE_ENABLE_MAGIC_LINK=true
FEATURE_ENABLE_SUBSCRIPTIONS=true
FEATURE_ENABLE_AI_FEATURES=false
FEATURE_WAITLIST_MODE=false

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
ADMIN_API_KEY=generate-a-secure-admin-key-here
ADMIN_EMAILS=admin@go2.gg

# Bearer token for internal admin endpoints at /admin/* (e.g., abuse-warning,
# resync-kv). Generate with `openssl rand -hex 32`. Rotate periodically.
ADMIN_TOKEN=generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Demo Mode
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=false
