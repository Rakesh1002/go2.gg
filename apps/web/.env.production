# =============================================================================
# Go2 Web - Production Environment
# =============================================================================
# This file contains environment variables for PRODUCTION builds.
# These values are baked into the Next.js bundle at build time.
# =============================================================================

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://go2.gg
NEXT_PUBLIC_API_URL=https://api.go2.gg

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=Go2
NEXT_PUBLIC_SITE_TAGLINE=The agentic URL shortener
NEXT_PUBLIC_SITE_DESCRIPTION=Go2 is the agentic URL shortener. Branded, tracked, revocable short links — minted from your AI agent's tool call into the workspace you already own. MCP, per-run attribution, custom domains, lifecycle controls. Edge-native on Cloudflare. Open source.

# -----------------------------------------------------------------------------
# PostHog (public project token — safe in client bundle)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_v3ADvZ6S36tkEkFdkWDQTSk49oaLjhJoky5Qm4SFmgmT
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# GA4 (public measurement ID — safe in client bundle, set when GA4 is enabled)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
